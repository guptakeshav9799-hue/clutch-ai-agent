# ============================================================
# Clutch — Client (Vite) Environment Variables
# Copy to: client/.env
# These are PUBLIC and will be embedded into the React bundle
# ============================================================

# --- Firebase Web App Config ---
# Get from: Firebase Console > Project Settings > Your Apps > Web App > Config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=clutch-500813.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=clutch-500813
VITE_FIREBASE_STORAGE_BUCKET=clutch-500813.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=299652595285
VITE_FIREBASE_APP_ID=299652595285:web:523572ba0841ae4561dedc

# --- FCM Web Push (VAPID Key) ---
# Get from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates > Generate key pair
VITE_FIREBASE_VAPID_KEY=BNpmwOunCbOi94gcW-qXlQmE1QUlAd1q88KeAajNZ4rRNps-Oal8J3Eu1x8sbuHGGcGcyYgVJNjQQueot1UoUis

# --- API URL ---
# Leave empty for local dev (Vite proxy handles it)
# Set to your Cloud Run URL in production, e.g: https://clutch-xxxxx-uc.a.run.app/api
VITE_API_URL=
